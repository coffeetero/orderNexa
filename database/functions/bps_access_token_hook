-- ============================================================
-- custom_access_token_hook
-- Purpose:
--   Enriches Supabase JWT claims with app-specific access context:
--   - app_user_id
--   - allowed_tenant_ids
--   - restricted_tenant_ids
--
-- Called from:
--   Supabase Auth "Custom Access Token Hook" during token issuance/refresh.
--   Supabase passes the auth event payload to this function and uses the
--   returned event.claims as the final JWT claims.
-- ============================================================

create or replace function bps_access_token_hook(event jsonb)
returns jsonb
language plpgsql
stable
security definer 
-- This line makes the function "schema-aware" without hardcoding it in the logic
SET search_path = bps, public 
as $$
declare
  claims jsonb;
  v_auth_user_id uuid;
  v_app_user_id bigint;
  v_allowed_tenant_ids bigint[];
  v_restricted_tenant_ids bigint[];
  v_allowed_customer_ids bigint[];

begin
  claims := event->'claims';
  v_auth_user_id := (event->>'user_id')::uuid;

  -- NO MORE PREFIXES: Generic and clean
  select usr.user_id
    into v_app_user_id
  from fnd_users usr
  where usr.auth_user_id = v_auth_user_id
    and usr.is_active = true;

  if v_app_user_id is null then
    claims := jsonb_set(claims, '{app_metadata,app_user_id}', 'null'::jsonb, true);
    claims := jsonb_set(claims, '{app_metadata,allowed_tenant_ids}', '[]'::jsonb, true);
    claims := jsonb_set(claims, '{app_metadata,restricted_tenant_ids}', '[]'::jsonb, true);
    return jsonb_set(event, '{claims}', claims, true);
  end if;

  select coalesce(array_agg(usrTnt.tenant_id order by usrTnt.tenant_id), '{}'::bigint[])
    into v_allowed_tenant_ids
  from fnd_user_tenants usrTnt
  where usrTnt.user_id = v_app_user_id
    and usrTnt.is_active = true;

  select coalesce(array_agg(usrTnt.tenant_id order by usrTnt.tenant_id), '{}'::bigint[])
    into v_restricted_tenant_ids
  from fnd_user_tenants usrTnt
  where usrTnt.user_id = v_app_user_id
    and usrTnt.is_active = true
    and usrTnt.is_customer_restricted = true;

  select coalesce(array_agg(uc.customer_id), '{}'::bigint[])
    into v_allowed_customer_ids
  from fnd_user_customers uc
  where uc.user_id = v_app_user_id
    and uc.is_active = true;


  -- Injection logic remains the same
  claims := jsonb_set(claims, '{app_metadata,app_user_id}', to_jsonb(v_app_user_id), true);
  claims := jsonb_set(claims, '{app_metadata,allowed_tenant_ids}', to_jsonb(v_allowed_tenant_ids), true);
  claims := jsonb_set(claims, '{app_metadata,restricted_tenant_ids}', to_jsonb(v_restricted_tenant_ids), true);

  claims := jsonb_set(claims, '{app_metadata,allowed_customer_ids}', to_jsonb(v_allowed_customer_ids), true);

  return jsonb_set(event, '{claims}', claims, true);
end;
$$;
